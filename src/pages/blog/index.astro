---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Base title="Blog — Myco@Home" description="Mushroom cultivation guides, tips, and tutorials from Myco@Home.">
  <h1>Blog</h1>
  <p class="sub">Cultivation guides, tips, and tutorials</p>

  <div class="post-list">
    {posts.map(post => (
      <a href={`/blog/${post.slug}`} class="post-card">
        <p class="post-date">{post.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <p class="post-title">{post.data.title}</p>
        <p class="post-desc">{post.data.description}</p>
      </a>
    ))}
    {posts.length === 0 && (
      <p class="empty">No posts yet — check back soon.</p>
    )}
  </div>
</Base>

<style>
.sub{font-size:14px;color:#666;margin-bottom:1.5rem;text-align:center}
.post-list{display:flex;flex-direction:column;gap:12px;margin-top:1.5rem}
.post-card{display:block;background:#fff;border:1px solid #ddd;border-radius:8px;padding:1.25rem 1.5rem;text-decoration:none;color:inherit}
.post-card:hover{border-color:#aaa}
.post-date{font-size:12px;color:#999;margin-bottom:4px}
.post-title{font-size:17px;font-weight:500;margin-bottom:6px;color:#222}
.post-desc{font-size:13px;color:#666;line-height:1.6}
.empty{font-size:14px;color:#aaa;text-align:center;padding:2rem 0}
</style>